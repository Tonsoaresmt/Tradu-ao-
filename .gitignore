# Ambiente Python do detector (~1.2 GB, recriável via detector/requirements.txt)
detector/.venv/
__pycache__/
*.pyc

# Node
node_modules/

# Modelos baixados (YOLO etc.)
*.pt
*.onnx

# Imagens de mangá: origem, páginas extraídas e saída (pesado / conteúdo protegido)
tradutor-manga/entrada-originais/*/
tradutor-manga/em-traducao/paginas/
tradutor-manga/traduzidos/*/
tradutor-manga/traduzidos/*.png
*.cbz

# Dados locais: trabalho de tradução (por capítulo) e memória de treino.
# São pessoais e mudam a cada uso (auto-save) — não vão pro repositório.
# O README de treino fica versionado como documentação.
tradutor-manga/em-traducao/projetos/
tradutor-manga/treino/exemplos.jsonl
tradutor-manga/treino/glossario.json
tradutor-manga/treino/estilo.txt

# Backups de reset locais
_backup-reset-*/

# Segredos e temporários
.env
*.log
.export-test/
.boot-*.log
.nodetest-*.log
